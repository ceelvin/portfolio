# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx

# Where contact form messages are delivered (defaults to contact@celvin.dev)
CONTACT_TO_EMAIL=contact@celvin.dev

# Sender address — must be a verified domain in Resend for production.
# For testing, Resend allows: Portfolio <onboarding@resend.dev>
RESEND_FROM_EMAIL=Portfolio <onboarding@resend.dev>